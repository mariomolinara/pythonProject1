# Copia questo file in .env e inserisci la tua API key
# cp .env.example .env  (oppure su Windows: copy .env.example .env)

# API key di Regolo.ai (o qualsiasi provider compatibile OpenAI)
# Ottienila gratis su https://regolo.ai
REGOLO_API_KEY=sk-LA_TUA_CHIAVE_QUI

# (Opzionale) Cambia endpoint se usi un altro provider compatibile OpenAI
# REGOLO_BASE_URL=https://api.regolo.ai/v1

# (Opzionale) Cambia modello
# REGOLO_MODEL=gpt-oss-120b

